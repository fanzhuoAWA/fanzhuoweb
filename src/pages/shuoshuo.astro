---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getEntry } from 'astro:content';
import MainCard from "@/components/MainCard.astro";
import TwikooComments from "@/components/TwikooComments.astro";

const entry = await getEntry('blog', '说说');
if (!entry) {
  throw new Error('说说 entry not found');
}
const { Content, headings } = await entry.render();
const entryData = entry.data;
---

<BaseLayout title="说说" headings={headings}>
  <MainCard
    title="说说"
    description={entryData.description}
    infoIcon="lucide:message-square"
  >
    <div class="shuoshuo-list">
      <Content />
    </div>
    <TwikooComments 
      envId="https://twikoo.fanzhuo.xyz/" 
    />
  </MainCard>
</BaseLayout>

<style>
  .shuoshuo-list {
    position: relative;
  }

  .shuoshuo-list :global(.shuoshuo-card) {
    position: relative;
    background: oklch(var(--b1));
    border-radius: 0.75rem;
    box-shadow: 0 1px 3px 0 oklch(var(--b3));
    border: 1px solid oklch(var(--bc) / 0.08);
    overflow: hidden;
    transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
  }

  .shuoshuo-list :global(.shuoshuo-card .quote-btn) {
    position: absolute;
    top: 0.35rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border: none;
    background: transparent;
    color: oklch(var(--bc) / 0.35);
    cursor: pointer;
    border-radius: 0.35rem;
    transition: color 0.2s, background 0.2s;
    padding: 0;
    line-height: 1;
    z-index: 1;
  }

  .shuoshuo-list :global(.shuoshuo-card .quote-btn:hover) {
    color: oklch(var(--p));
    background: oklch(var(--p) / 0.1);
  }

  .shuoshuo-list :global(.shuoshuo-card .quote-btn svg) {
    width: 1rem;
    height: 1rem;
  }

  .shuoshuo-list :global(.shuoshuo-card:hover) {
    box-shadow: 0 8px 20px -5px oklch(var(--b3));
    transform: translateY(-2px);
  }

  .shuoshuo-list :global(.shuoshuo-card h1) {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    margin: 0;
    background: linear-gradient(to right, oklch(var(--p) / 0.06), transparent);
    border-bottom: 1px solid oklch(var(--bc) / 0.08);
  }

  .shuoshuo-list :global(.shuoshuo-card > *:not(h1)) {
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .shuoshuo-list :global(.shuoshuo-card > p) {
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: oklch(var(--bc));
  }

  .shuoshuo-list :global(.shuoshuo-card > p:first-of-type) {
    padding-top: 0.5rem;
  }

  .shuoshuo-list :global(.shuoshuo-card > p:last-child) {
    padding-bottom: 0.5rem;
  }

  .shuoshuo-list :global(.shuoshuo-card img) {
    border-radius: 0.4rem;
    margin: 0.25rem 0;
    max-width: 100%;
    height: auto;
  }

  .shuoshuo-list :global(.shuoshuo-card video) {
    border-radius: 0.4rem;
    margin: 0.25rem 0;
    max-width: 100%;
  }

  .shuoshuo-list :global(.shuoshuo-card blockquote) {
    border-left: 2px solid oklch(var(--p) / 0.5);
    padding: 0.25rem 0.6rem;
    margin: 0.25rem 0;
    font-size: 0.8rem;
    background: oklch(var(--b2) / 0.5);
    border-radius: 0 0.4rem 0.4rem 0;
    color: oklch(var(--bc) / 0.8);
    font-style: italic;
  }

  .shuoshuo-list :global(.shuoshuo-card del) {
    color: oklch(var(--bc) / 0.5);
    text-decoration: line-through;
  }
</style>

<script>
  function splitCards(container: HTMLElement) {
    const children = [...container.children];
    if (children.length === 0) return false;
    if (children[0].classList.contains('shuoshuo-card')) return false;

    const fragment = document.createDocumentFragment();
    let currentCard: HTMLDivElement | null = null;

    for (const child of children) {
      if (child.tagName === 'H1') {
        currentCard = document.createElement('div');
        currentCard.className = 'shuoshuo-card';
        currentCard.appendChild(child);
        fragment.appendChild(currentCard);
      } else if (currentCard) {
        currentCard.appendChild(child);
      } else {
        fragment.appendChild(child);
      }
    }

    container.appendChild(fragment);
    return true;
  }

  function addQuoteButtons(cards: NodeListOf<HTMLElement>) {
    for (const card of cards) {
      if (card.querySelector('.quote-btn')) continue;

      const btn = document.createElement('button');
      btn.className = 'quote-btn';
      btn.title = '\u5F15\u7528\u5230\u8BC4\u8BBA';
      btn.innerHTML =
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>';

      btn.addEventListener('click', (e: Event) => {
        e.stopPropagation();

        let textParts: string[] = [];
        for (const child of card.children) {
          if (child.tagName === 'H1') continue;
          const text = (child as HTMLElement).textContent?.trim();
          if (text) textParts.push(text);
        }
        const quoteText = textParts.join('\n');

        const twikooEl = document.getElementById('twikoo');
        if (!twikooEl) return;

        twikooEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

        setTimeout(() => {
          const textarea = document.querySelector('#twikoo .el-textarea__inner') as HTMLTextAreaElement | null;
          if (textarea) {
            const quoted = '> ' + quoteText.replace(/\n/g, '\n> ') + '\n\n';
            textarea.value = quoted;
            textarea.dispatchEvent(new Event('input', { bubbles: true, cancelable: true }));
            textarea.focus();
            textarea.selectionStart = textarea.selectionEnd = textarea.value.length;
          }
        }, 600);
      });

      card.appendChild(btn);
    }
  }

  function masonry() {
    const container = document.querySelector('.shuoshuo-list') as HTMLElement | null;
    if (!container) return;
    const cards = container.querySelectorAll(':scope > .shuoshuo-card') as NodeListOf<HTMLElement>;
    if (!cards.length) return;

    const gap = 8;
    const cols = 2;
    const colW = (container.clientWidth - gap) / cols;

    const h = [0, 0];

    for (const card of cards) {
      card.style.position = 'absolute';
      card.style.width = colW + 'px';

      const idx = h[0] <= h[1] ? 0 : 1;
      card.style.left = idx ? (colW + gap) + 'px' : '0';
      card.style.top = h[idx] + 'px';

      h[idx] += card.offsetHeight + gap;
    }

    container.style.height = Math.max(h[0], h[1]) - gap + 'px';
    container.style.position = 'relative';
  }

  function initMasonry() {
    const container = document.querySelector('.shuoshuo-list') as HTMLElement | null;
    if (!container) return;

    splitCards(container);

    const cards = container.querySelectorAll(':scope > .shuoshuo-card');
    if (!cards.length) return;

    addQuoteButtons(cards);

    const imgs = container.querySelectorAll('img');
    const videos = container.querySelectorAll('video');
    let pending = imgs.length + videos.length;

    if (pending === 0) {
      masonry();
      return;
    }

    for (const el of imgs) {
      if (el.complete) {
        pending--;
        if (pending === 0) masonry();
      } else {
        el.addEventListener('load', () => {
          pending--;
          if (pending === 0) masonry();
        });
        el.addEventListener('error', () => {
          pending--;
          if (pending === 0) masonry();
        });
      }
    }

    for (const el of videos) {
      if (el.readyState >= 3) {
        pending--;
        if (pending === 0) masonry();
      } else {
        el.addEventListener('loadeddata', () => {
          pending--;
          if (pending === 0) masonry();
        });
        el.addEventListener('error', () => {
          pending--;
          if (pending === 0) masonry();
        });
      }
    }
  }

  function tryInitMasonry() {
    const container = document.querySelector('.shuoshuo-list');
    if (container) {
      requestAnimationFrame(() => initMasonry());
    }
  }

  document.addEventListener("astro:page-load", initMasonry);
  tryInitMasonry();

  let timer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(timer);
    timer = setTimeout(initMasonry, 150);
  });
</script>
