---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import TwikooComments from "@/components/TwikooComments.astro";
---

<BaseLayout title="朋友圈">
    <MainCard
      title="朋友圈"
      description="朋友们的最新文章"
      infoIcon="material-symbols:rss-feed"
    >
    <div class="space-y-10">
      <section>
        <div id="friend-circle-lite-root"></div>
      </section>
    </div>
    <TwikooComments 
      envId="https://twikoo.fanzhuo.xyz/" 
    />
    </MainCard>
</BaseLayout>

<!-- 引用 Stars-harbor 版的 CSS（从你的 page 分支加载） -->
<link
  rel="stylesheet"
  href="https://friend-circle-lite-2mm.pages.dev/main/fclite.css"
/>

<script>
  function initFcircle() {
    const root = document.getElementById('friend-circle-lite-root');
    if (!root) return;

    // 清空容器
    root.innerHTML = '';

    (window as any).UserConfig = {
      private_api_url: 'https://friend-circle-lite-2mm.pages.dev/',
      page_turning_number: 24,
      error_img: 'https://friend-circle-lite-2mm.pages.dev/favicon.ico',
    };

    // 移除旧的 script
    const existingScript = document.querySelector('script[data-fcircle="true"]');
    if (existingScript) {
      existingScript.remove();
    }

    // 加载 Stars-harbor 版的 JS
    const script = document.createElement('script');
    script.src = 'https://friend-circle-lite-2mm.pages.dev/main/fclite.js';
    script.defer = true;
    script.dataset.fcircle = 'true';
    document.head.appendChild(script);
  }

  // 首次加载执行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFcircle);
  } else {
    initFcircle();
  }

  // 监听 Astro 页面切换
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initFcircle, 100);
  });

  document.addEventListener('swup:content:replace', () => {
    setTimeout(initFcircle, 100);
  });
</script>

<style is:global>
/* ===== 修复星星港湾版朋友圈的样式冲突 ===== */

/* 1. 修复卡片悬停抖动，消除Frosti全局过渡的干扰 */
#friend-circle-lite-root .card,
#friend-circle-lite-root #random-article {
  transition: border 0.25s ease, transform 0.25s ease !important;
  will-change: transform;
}

#friend-circle-lite-root .card:hover,
#friend-circle-lite-root #random-article:hover {
  transform: translateY(-2px) !important;
}

/* 卡片内部元素不继承 Frosti 的全局过渡 */
#friend-circle-lite-root .card *,
#friend-circle-lite-root #random-article * {
  transition: none !important;
}

/* 恢复卡片内部特定元素的过渡 */
#friend-circle-lite-root .card-title {
  transition: color 0.25s ease !important;
}
#friend-circle-lite-root .card-bg {
  transition: transform 0.6s ease, bottom 0.3s ease, right 0.3s ease !important;
}
#friend-circle-lite-root #load-more-btn {
  transition: all 0.25s ease !important;
}
#friend-circle-lite-root .random-link-button {
  transition: background-color 0.25s ease-in-out !important;
}

/* 2. 修复随机钓鱼的字体动画 */
#friend-circle-lite-root #random-article .random-container .random-title {
  transition: font-size 0.3s ease-in-out !important;
}
#friend-circle-lite-root #random-article .random-container:hover .random-title {
  font-size: 32px !important;
}
#friend-circle-lite-root #random-article .random-container {
  transition: none !important;
}

/* 3. 强制显示边框，并使用Frosti的主题色变量 */
#friend-circle-lite-root .card,
#friend-circle-lite-root #random-article {
  border: 1px solid var(--border-color, oklch(var(--b2))) !important;
}
#friend-circle-lite-root .card:hover,
#friend-circle-lite-root #random-article:hover {
  border-color: oklch(var(--p)) !important;
}

/* 4. 使用Frosti主题色变量控制所有主要交互颜色 */
#friend-circle-lite-root .card-title:hover {
  color: oklch(var(--p)) !important;
}
#friend-circle-lite-root .random-link-button {
  background-color: oklch(var(--p)) !important;
}
#friend-circle-lite-root .random-link-button:hover {
  background-color: oklch(var(--p) / 0.8) !important;
}
#friend-circle-lite-root #load-more-btn:hover {
  background-color: oklch(var(--p)) !important;
  border-color: oklch(var(--p)) !important;
  color: oklch(var(--pc)) !important;
}
#friend-circle-lite-root #modal-author-name-link {
  color: oklch(var(--p)) !important;
}
#friend-circle-lite-root .stat-num {
  color: oklch(var(--p)) !important;
}
#friend-circle-lite-root .modal-article .modal-article-title:hover {
  color: oklch(var(--p)) !important;
}

#friend-circle-lite-root .random-link-button {
  border-radius: 6px !important;
}

/* ===== 新增：文章卡片背景改为类似友链卡的渐变样式 ===== */
#friend-circle-lite-root .card {
  background: linear-gradient(to bottom right, oklch(var(--p) / 0.2), oklch(var(--b1))) !important;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
  border-color: oklch(var(--p) / 0.3) !important;
}

#friend-circle-lite-root .card:hover {
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
  transform: translateY(-2px) !important;
  border-color: oklch(var(--p)) !important;
}
/* ===== 随机钓鱼卡片添加渐变背景 ===== */
#friend-circle-lite-root #random-article {
  background: linear-gradient(to bottom right, oklch(var(--p) / 0.15), oklch(var(--b1))) !important;
  border-color: oklch(var(--p) / 0.25) !important;
}

#friend-circle-lite-root #random-article:hover {
  border-color: oklch(var(--p)) !important;
}


/* ===== 模态框样式适配 Frosti ===== */

#friend-circle-lite-root .modal-content {
  background: oklch(var(--b1)) !important;
  border: 1px solid oklch(var(--bc) / 0.1) !important;
  border-radius: 0.75rem !important;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12) !important;
  padding: 1.5rem !important;
}

#friend-circle-lite-root #modal-author-avatar {
  width: 64px !important;
  height: 64px !important;
  border: 2px solid oklch(var(--p)) !important;
  box-shadow: 0 0 0 2px oklch(var(--b1)) !important;
}

#friend-circle-lite-root #modal-author-name-link {
  font-size: 1.1rem !important;
  font-weight: 600 !important;
  color: oklch(var(--p)) !important;
  text-decoration: none !important;
  margin: 0.5rem 0 0.25rem 0 !important;
}

#friend-circle-lite-root #modal-author-name-link:hover {
  text-decoration: underline !important;
}

#friend-circle-lite-root #modal-articles-container {
  border-top: 1px solid oklch(var(--bc) / 0.1) !important;
  margin-top: 0.75rem !important;
  padding-top: 0.75rem !important;
}

#friend-circle-lite-root .modal-article {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  padding: 0.5rem 0 !important;
  border-bottom: 1px solid oklch(var(--bc) / 0.05) !important;
}

#friend-circle-lite-root .modal-article:last-child {
  border-bottom: none !important;
}

#friend-circle-lite-root .modal-article .modal-article-title {
  color: oklch(var(--bc)) !important;
  font-size: 0.9rem !important;
  font-weight: 500 !important;
  text-decoration: none !important;
  transition: color 0.25s ease, transform 0.25s ease !important;
  max-width: 70% !important;
  display: inline-block !important;
  -webkit-line-clamp: 1 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

#friend-circle-lite-root .modal-article .modal-article-title:hover {
  color: oklch(var(--p)) !important;
  transform: translateX(4px) !important;
  text-decoration: underline !important;
}

#friend-circle-lite-root .modal-article .modal-article-title:hover {
  color: oklch(var(--p)) !important;
  text-decoration: underline !important;
}

#friend-circle-lite-root .modal-article .modal-article-date {
  color: oklch(var(--bc) / 0.4) !important;
  font-size: 0.75rem !important;
  flex-shrink: 0 !important;
}

#friend-circle-lite-root .modal {
  background-color: rgba(0, 0, 0, 0.4) !important;  /* 纯黑半透明，无毛玻璃 */
}

/* 暗色模式下微调 */
[data-theme-type="dark"] #friend-circle-lite-root .modal-content {
  border-color: oklch(var(--bc) / 0.15) !important;
}
</style>