---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import LinkCard from "@/components/mdx/LinkCard.astro";
import FriendCard from "@/components/mdx/FriendCard.astro";
import Card from "@/components/temple/Card.astro";
import CardGroup from "@/components/temple/CardGroup.astro";
import Showcase from "@/components/mdx/Showcase.astro";

const sites = [{ name: "Frosti Demo", url: "https://frosti.saroprock.com/" }];
---

<BaseLayout title="Friends">
  <CardGroup cols="1">
    <MainCard
      title="友链"
      description="我的朋友、其他项目的链接集合"
      textOverlay="Friends"
      infoIcon="lucide:link"
    >
      <div class="space-y-10">
        <!-- Friends Section -->
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:users" class="w-6 h-6 text-primary" />
            <span>朋友</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="EveSunMaple"
              avatar="https://github.com/EveSunMaple.png"
              description="这个主题的作者"
              url="https://www.saroprock.com/"
              type="friend"
            />
            <FriendCard
              name="Purinliang"
              avatar="https://avatars.githubusercontent.com/u/68161856?v=4"
              description="ICPC Gold Medalist - from the 2020 ICPC Asia Kunming Regional Contest"
              url="https://github.com/purinliang"
              type="friend"
            />
          </div>
        </section>

        <!-- Contributors Section -->
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:git-pull-request" class="w-6 h-6 text-primary" />
            <span>其他项目</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="我的旧版博客"
              avatar="https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAMmaKLG3HIXnDabb0_1QIY8zrjkS5oAAuLIMRtRWRhVhfFnFjfrdGsBAAMCAAN5AAM2BA.png"
              description="ˋ( ° ▽、° ) "
              url="https://fanzhuo.xyz/"
              type="contributor"
            />
            <FriendCard
              name="我的图床"
              avatar="https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAMoaKLH3Pbn0veaTF6leFHMbQdL3jAAAgrJMRtRWRhVzL8nb3s1ngcBAAMCAANtAAM2BA.png"
              description="基于 Telegraph 的图片上传工具，本站大多数图片都是用这个图床上传的喔"
              url="https://image.fanzhuo.xyz/"
              type="contributor"
            />
            <FriendCard
              name="我的Minecraft服务器的介绍网站"
              avatar="https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAMqaKLIXWHx6PLW0W1tGPwO3kn61_gAAhHJMRtRWRhV426aOPyKcngBAAMCAAN4AAM2BA.png"
              description="awa"
              url="https://sever.fanzhuo.xyz/"
              type="contributor"
            />
            <FriendCard
              name="飞屋工作室官网"
              avatar="https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAMraKLI-yOETmWda-aOZGfci6CRFlYAAhXJMRtRWRhVQ4v61qfQOS0BAAMCAAN5AAM2BA.png"
              description="我为飞屋工作室搭建的官网"
              url="https://shg.fanzhuo.xyz/"
              type="contributor"
            />
          </div>
        </section>

        <!-- Useful Resources Section -->
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:bookmark" class="w-6 h-6 text-primary" />
            <span>实用工具</span>
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <LinkCard
              title="Astro Documentation"
              desc="The official documentation for Astro, covering everything from getting started to advanced techniques."
              url="https://docs.astro.build"
              icon="simple-icons:astro"
              categories={["Docs", "Learning", "Reference"]}
            />

            <LinkCard
              title="Tailwind CSS Documentation"
              desc="Learn how to use Tailwind's utility classes to style your website without writing CSS."
              url="https://tailwindcss.com/docs"
              icon="simple-icons:tailwindcss"
              categories={["Docs", "CSS", "Reference"]}
            />

            <LinkCard
              title="DaisyUI Components"
              desc="Browse DaisyUI's component library and learn how to use them in your project."
              url="https://daisyui.com/components/"
              icon="simple-icons:daisyui"
              categories={["Components", "UI", "Reference"]}
            />

            <LinkCard
              title="TypeScript Handbook"
              desc="The TypeScript Handbook is a comprehensive guide to the TypeScript language."
              url="https://www.typescriptlang.org/docs/handbook/intro.html"
              icon="simple-icons:typescript"
              categories={["Docs", "TypeScript", "Reference"]}
            />
          </div>
        </section>

        <div class="divider my-8">
          <Icon name="lucide:heart" class="w-10 h-10 text-primary" />
        </div>

        <div class="text-center">
          <p class="text-base-content/80 mb-4">
            Want to be featured on this page? Feel free to reach out or contribute to the project!
          </p>
          <a
            href="https://github.com/EveSunMaple/Frosti"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary gap-2"
          >
            <Icon name="lucide:github" class="w-5 h-5" />
            <span>Contribute on GitHub</span>
          </a>
        </div>
      </div>
    </MainCard>
    <Card>
      <div class="p-4 sm:p-6">
        <div class="space-y-10">
          <section>
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-2">
              <h2 class="text-2xl font-bold flex items-center gap-2">
                <Icon name="lucide:layout-template" class="w-6 h-6 text-primary" />
                <span>Sites Using Frosti</span>
              </h2>
              <a
                href="https://github.com/EveSunMaple/Frosti/edit/main/src/pages/friend.astro"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm btn-outline btn-primary gap-2"
              >
                <Icon name="lucide:plus-circle" class="w-4 h-4" />
                Add Your Site
              </a>
            </div>
            <p class="text-base-content/70 mb-6">
              Here is a list of sites built with Frosti. Want to get your site listed? Click the "Add Your Site" button
              in the top right to edit this page by submitting a Pull Request!
            </p>
            <div class="flex flex-wrap items-center gap-3">
              {sites.map((site) => <Showcase name={site.name} url={site.url} />)}
            </div>
          </section>
        </div>
      </div>
    </Card>
  </CardGroup>
</BaseLayout>
