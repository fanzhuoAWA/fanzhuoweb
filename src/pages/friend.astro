---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import LinkCard from "@/components/mdx/LinkCard.astro";
import FriendCard from "@/components/mdx/FriendCard.astro";
import Card from "@/components/temple/Card.astro";
import CardGroup from "@/components/temple/CardGroup.astro";
import Showcase from "@/components/mdx/Showcase.astro";
import Waline from "@/components/Waline.astro";
import Collapse from "@/components/mdx/Collapse.astro";
import TwikooComments from "@/components/TwikooComments.astro";

const sites = [{ name: "Frosti Demo", url: "https://frosti.saroprock.com/" }];
---

<BaseLayout title="Friends">
  <CardGroup cols="1">
    <MainCard
      title="友链"
      description="我的朋友、友情链接和其他链接的集合"
      image = "https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAOUaVCxH8yTDNi4oPGF5XkMplml2CoAAscLaxtWrYhWgYkwnxv0GW4BAAMCAAN3AAM2BA.png"
      infoIcon="lucide:link"
    >
      <div class="space-y-10">
        <!-- Friends Section -->
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:users" class="w-6 h-6 text-primary" />
            <span>好友</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="Purinliang"
              avatar="https://purinliang.github.io/android-chrome-192x192.png"
              description="I am a developer and I share my interests and thoughts on various topics here."
              url="https://purinliang.github.io/"
              type="friend"
            />
            <FriendCard
              name="EveSunMaple"
              avatar="https://avatars.githubusercontent.com/u/121652165?v=4"
              description="热爱技术，喜欢记录生活中的点点滴滴。"
              url="https://www.saroprock.com/"
              type="friend"
            />
            <FriendCard
              name="FeltSquirrel727"
              avatar="https://blog.tbedu.top/profile.png"
              description="一名热爱生活、热爱编程的高中学生"
              url="https://blog.tbedu.top/"
              type="friend"
            />
            <FriendCard
              name="Gavin蔚蔚"
              avatar="https://cdn-community.bcmcdn.com/47/community/d2ViXzEwMDFfMzc5NTQyNjE5XzM3OTU0MjYxOV8xNzUwNTg4NTgyMDI4XzUwZjg1MTcz.jpeg"
              description="生死茫茫，大梦一场"
              url="https://www.douyin.com/user/MS4wLjABAAAAVvOO2Zu_xtVxRgsFsEfssX-0G6jP5ifKzufUw5fSZquxXqkg6HmljjGoOfYWuqX8?from_tab_name=main"
              type="friend"
            />
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="ri:flower-line" class="w-6 h-6 text-primary" />
            <span>感谢名单</span>
          </h2>
          感谢在 <a href="https://afdian.com/a/fanzhuo" target="_blank" class="text-primary font-bold hover:text-primary-focus">爱发电</a> 支持我的朋友！
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="Amani"
              avatar="https://image.fanzhuo.xyz/file/AgACAgUAAyEGAASKws10AAOfaVEgJtIThM0IJxcU6wABqbCSd2BoAALuDGsbVq2IVq6y35ac08zGAQADAgADeAADNgQ.jpg"
              description="这个家伙很懂PFAS"
              url="http://pfasnews.com/"
              type="friend"
            />
          </div>
        </section>
        <!-- Contributors Section -->
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:git-pull-request" class="w-6 h-6 text-primary" />
            <span>友情链接</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="❖星港◎Star☆"
              avatar="https://bu.dusays.com/2025/04/11/67f92f6fcfb26.webp"
              description="以博客记录生活与热爱！"
              url="https://blog.starsharbor.com/"
              type="contributor"
            />
            <FriendCard
              name="异站"
              avatar="https://image.tabirstrees.top/images/2025/02/22/tabirstrees.png"
              description="晴耕雨读"
              url="https://www.tabirstrees.top/"
              type="contributor"
            />
            <FriendCard
              name="xyx404"
              avatar="https://fastly.jsdelivr.net/npm/xyx404blogphoto@1.2.23/avatar.webp"
              description="在努力和摆烂中选择了努力摆烂 AWA"
              url="https://xyx404.github.io/"
              type="contributor"
            />
            <FriendCard
              name="阿猪"
              avatar="https://yfzhu.cn/assets/img/favicon.png"
              description="计算机、股票业余爱好者"
              url="https://yfzhu.cn/"
              type="contributor"
            />
            <FriendCard
              name="Chlorine"
              avatar="https://chlo.is/img/avatars/02.avif"
              description="An Element-chan who writes."
              url="https://chlo.is"
              type="contributor"
            />
            <FriendCard
              name="白鱼小栈"
              avatar="https://www.baiyuyu.com/avatar.jpg"
              description="技术宅拯救世界"
              url="https://www.baiyuyu.com"
              type="contributor"
            />
            <FriendCard
              name="清羽飞扬"
              avatar="https://blog.liushen.fun/info/avatar.ico"
              description="柳影曳曳，清酒孤灯，扬笔撒墨，心境如霜"
              url="https://blog.liushen.fun/"
              type="contributor"
            />
          </div>
        </section>
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:layout-template" class="w-6 h-6 text-primary" />
            <span>其他链接</span>
          </h2>
          <div class="flex items-center flex-wrap gap-3"><!--<a href="https://fanzhuo.xyz/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="我的另一个搭建中的博客awa"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">fanzhuo's blog</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>-->
          <a href="https://image.fanzhuo.xyz/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="我搭建的图片托管工具"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">图床</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>
          <a href="https://sanatian.fanzhuo.xyz/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="乌斯托什语词典"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">Uweztoße</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>
          <a href="https://shg.fanzhuo.xyz/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="由我搭建的"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">飞屋工作室官网</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>
          <a href="https://www.imgcc.cloud/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="图片托管工具"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">imgcc</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>
          <a href="https://csacademy.com/app/graph_editor/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="建图工具"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">Graph Editor</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script>
          <a href="https://bg.diyun.site/" class="btn btn-sm btn-outline gap-2 website-badge" target="_blank" rel="noopener noreferrer" title="在线创建精美渐变背景"><div class="flex items-center rounded-full bg-gray-200 h-3 justify-center status-dot w-3" title="Online"><div class="h-2 rounded-full w-2 bg-green-500"></div></div><span class="font-medium">渐变背景生成器</span></a><script type="module" data-astro-exec="">document.addEventListener("astro:page-load",(()=>{document.querySelectorAll(".website-badge").forEach((e=>{const t=e.getAttribute("href");if(!t)return;const r=e.querySelector(".status-dot");if(!r)return;const s=r.querySelector("div");if(!s)return;const o=new AbortController,a=setTimeout((()=>o.abort()),5e3);fetch(t,{method:"HEAD",mode:"no-cors",signal:o.signal}).then((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-green-500"),r.setAttribute("title","Online")})).catch((()=>{s.classList.remove("bg-gray-400"),s.classList.add("bg-red-500"),r.setAttribute("title","Offline or unreachable")})).finally((()=>{clearTimeout(a)}))}))}))</script></div>
        </section>
        <Collapse title="折叠的友链">
          这里收录了出现问题的友链，问题原因包括但不限于：网站搭建中、持续无法访问、长期未更新等。
          <br><br>
          如果已解决问题可以在下方评论告知。
          <br><br>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">


          </div>
        </Collapse>
        <div class="divider my-8">
          <Icon name="lucide:heart" class="w-10 h-10 text-primary" />
        </div>        
        <section class="comments">
          <h2>欢迎交换友链！在这里申请！</h2>

  <div class="friend-apply-card">
    <div class="apply-section">
      <div class="section-title">请确认你的网站符合以下内容：</div>
      <ul class="check-list">
        <li>已添加 Fanzhuo's blog 博客的友情链接</li>
        <li>链接主体为个人，网站类型为博客</li>
        <li>网站现在可以在中国大陆区域正常访问</li>
        <li>网站内容符合中国大陆法律法规</li>
      </ul>
    </div>

    <div class="apply-section">
      <div class="section-title">申请格式与本站信息：</div>
      <div class="info-grid">
        <div class="info-row"><span class="info-label">站点名称：</span><span class="info-value">Fanzhuo's blog</span></div>
        <div class="info-row"><span class="info-label">站点链接：</span><span class="info-value"><a href="https://fanzhuo.xyz/" target="_blank" rel="noopener">https://fanzhuo.xyz/</a></span></div>
        <div class="info-row"><span class="info-label">站点图标：</span><span class="info-value"><a href="https://fanzhuo.xyz/profile.png" target="_blank" rel="noopener">https://fanzhuo.xyz/profile.png</a></span></div>
        <div class="info-row"><span class="info-label">站点介绍：</span><span class="info-value">我的开发日志、生活随笔与算法浅谈。</span></div>
        <div class="info-row"><span class="info-label">rss（选填）：</span><span class="info-value"><a href="https://fanzhuo.xyz/rss.xml" target="_blank" rel="noopener">https://fanzhuo.xyz/rss.xml</a></span></div>
