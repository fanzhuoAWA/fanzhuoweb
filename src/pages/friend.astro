</BaseLayout>

<style>
/* 友链申请卡片样式 - 适配 Frosti 主题 */
.friend-apply-card {
  background: oklch(var(--b1));
  border-radius: 1rem;
  padding: 1.5rem;
  margin: 1.5rem 0;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  border: 1px solid oklch(var(--bc) / 0.1);
}

.apply-section {
  margin-bottom: 1.75rem;
}

.apply-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-weight: 600;
  font-size: 1rem;
  margin-bottom: 0.75rem;
  color: oklch(var(--bc));
}

.check-list {
  list-style: none;
  padding-left: 1.75rem;
  margin: 0;
}

.check-list li {
  margin: 0.5rem 0;
  color: oklch(var(--bc) / 0.8);
  position: relative;
  line-height: 1.5;
}

.check-list li::before {
  content: "✓";
  color: oklch(var(--p));
  font-weight: bold;
  position: absolute;
  left: -1.5rem;
}

.info-grid {
  background: oklch(var(--b2) / 0.5);
  border-radius: 0.75rem;
  padding: 1rem 1.25rem;
}

.info-row {
  display: flex;
  flex-wrap: wrap;
  margin: 0.5rem 0;
  font-size: 0.875rem;
}

.info-label {
  width: 5rem;
  font-weight: 600;
  color: oklch(var(--bc) / 0.7);
}

.info-value {
  flex: 1;
  color: oklch(var(--bc));
  word-break: break-all;
}

.info-value a {
  color: oklch(var(--p));
  text-decoration: none;
}

.info-value a:hover {
  text-decoration: underline;
}
</style>