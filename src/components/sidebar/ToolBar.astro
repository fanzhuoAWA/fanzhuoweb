---
import { Icon } from "astro-icon/components";
import ThemeToggle from "../widgets/ThemeToggle.astro";
import { t } from "@config";
import type { TOCBarProps } from "@interfaces/data";

const { headings = [], showTOC = true } = Astro.props as TOCBarProps;
---

<div
  id="toolbar-frame"
  class="fixed bottom-4 right-6 z-50 border border-white/20 rounded-2xl bg-base-100/80 backdrop-blur-sm shadow-lg transition-all duration-300"
>
  <div class="flex flex-col items-end p-3">
    <div class="flex flex-col items-end gap-2">
      <a
        href="/blog/tags"
        class="btn btn-circle btn-md bg-base-100 shadow-sm hover:scale-110"
        aria-label={t("label.tagPage")}
        title={t("label.tagPage")}
      >
        <Icon name="lucide:tag" class="w-5 h-5" />
      </a>

      <a
        href="/blog/categories"
        class="btn btn-circle btn-md bg-base-100 shadow-sm hover:scale-110"
        aria-label={t("label.categoryPage")}
        title={t("label.categoryPage")}
      >
        <Icon name="lucide:folder" class="w-5 h-5" />
      </a>

      <a
        href="/blog/archives"
        class="btn btn-circle btn-md bg-base-100 shadow-sm hover:scale-110"
        aria-label={t("label.archivePage")}
        title={t("label.archivePage")}
      >
        <Icon name="lucide:archive" class="w-5 h-5" />
      </a>

      <ThemeToggle className="sidebar-theme max-md:hidden" />

      {showTOC && headings.length > 0 && (
        <button
          id="mobile-toc-button"
          class="btn btn-circle btn-md bg-base-100 shadow-sm hover:scale-110 md:hidden"
          aria-label={t("label.tableOfContents")}
          title={t("label.tableOfContents")}
          onclick="mobile_toc_modal.showModal()"
        >
          <Icon name="lucide:list" class="w-5 h-5" />
        </button>
      )}
    </div>

    <div
      id="scroll-to-top-wrapper"
      style="overflow: hidden; height: 0; transition: height 0.3s ease;"
    >
      <button
        id="scroll-to-top"
        aria-label="Scroll to top"
        class="btn btn-circle btn-md bg-base-100 shadow-sm hover:scale-110 mt-2 opacity-0 invisible transition-all duration-300"
      >
        <Icon name="material-symbols:arrow-upward-rounded" class="h-5 w-5" />
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const scrollButton = document.getElementById("scroll-to-top");
    const scrollWrapper = document.getElementById("scroll-to-top-wrapper");

    if (scrollButton && scrollWrapper) {
      const updateState = () => {
        if (window.scrollY > 300) {
          scrollWrapper.style.overflow = "visible";
          scrollWrapper.style.height = (scrollButton.offsetHeight + 8) + "px";
          scrollButton.classList.remove("opacity-0", "invisible");
          scrollButton.classList.add("opacity-100", "visible");
        } else {
          scrollWrapper.style.overflow = "hidden";
          scrollWrapper.style.height = "0";
          scrollButton.classList.remove("opacity-100", "visible");
          scrollButton.classList.add("opacity-0", "invisible");
        }
      };

      updateState();

      window.addEventListener("scroll", updateState, { passive: true });

      scrollButton.addEventListener("click", () => {
        window.scrollTo({
          top: 0,
          behavior: "smooth",
        });
      });
    }
  });
</script>
