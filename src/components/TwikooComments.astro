---
interface Props {
  envId: string;
  path?: string;
}

const { envId, path } = Astro.props;
---

<!-- 提前加载 Twikoo 的 CSS -->
<link rel="preload" href="https://cdn.jsdelivr.net/npm/twikoo@1.7.11/dist/twikoo.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/twikoo@1.7.11/dist/twikoo.css"></noscript>

<!-- 备用的内联样式，确保在 CSS 加载前不会碎掉 -->
<style is:global>
  #twikoo {
    min-height: 200px;
  }
  #twikoo .tk-comment-container {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>

<div class="mt-8">
  <h2 class="frosti-heading !text-lg mb-4">评论</h2>
  <div 
    id="twikoo"
    data-env-id={envId}
    data-path={path || 'auto'}
  >
    <div class="flex items-center justify-center py-8 text-base-content/60">
      <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-primary mr-2"></div>
      正在加载评论...
    </div>
  </div>
</div>

<!-- 使用 defer 属性延迟执行，确保 DOM 就绪 -->
<script 
  src="https://cdn.jsdelivr.net/npm/twikoo@1.7.11/dist/twikoo.min.js"
  defer
></script>

<!-- marked 用于客户端渲染 markdown -->
<script 
  src="https://cdn.jsdelivr.net/npm/marked@14.1.4/marked.min.js"
  defer
></script>

<!-- 内联脚本处理初始化 -->
<script is:inline>
  // 全局变量存储重试次数
  window.twikooRetryCount = 0;
  window.maxRetries = 20; // 最大重试次数

  function waitForTwikoo(callback, retryCount = 0) {
    if (typeof window.twikoo !== 'undefined') {
      callback();
    } else if (retryCount < window.maxRetries) {
      setTimeout(() => waitForTwikoo(callback, retryCount + 1), 200);
    } else {
      console.error('Twikoo failed to load after maximum retries');
      showErrorMessage();
    }
  }

  function showErrorMessage() {
    const containers = document.querySelectorAll('#twikoo');
    containers.forEach(container => {
      if (container) {
        container.innerHTML = `
          <div class="text-center py-8 text-red-500">
            <p>评论系统加载失败</p>
            <button onclick="location.reload()" class="btn btn-primary btn-sm mt-2">
              重新加载
            </button>
          </div>
        `;
      }
    });
  }

  function setupOwOFix() {
    const card = document.querySelector('.bg-base-100.rounded-xl.shadow-lg.w-full.overflow-hidden');
    if (!card) return;

    const ro = new MutationObserver(() => {
      const owoOpen = document.querySelector('#twikoo .OwO.OwO-open');
      if (owoOpen) {
        card.style.overflow = 'visible';
      } else {
        card.style.overflow = '';
      }
    });

    const container = document.getElementById('twikoo');
    if (container) {
      ro.observe(container, { subtree: true, attributes: true, attributeFilter: ['class'] });
    }
  }

  function renderCommentMarkdown() {
    if (typeof window.marked === 'undefined') {
      setTimeout(renderCommentMarkdown, 300);
      return;
    }
    const spans = document.querySelectorAll('#twikoo .tk-content > span:not([data-md])');
    for (const span of spans) {
      span.setAttribute('data-md', '1');
      const html = span.innerHTML.trim();
      if (/^[>*#\-\d.]|!\[|\[.*\]\(/.test(html)) {
        span.innerHTML = window.marked.parse(html);
      }
    }
  }

  function initializeTwikoo() {
    const container = document.getElementById('twikoo');
    
    if (!container) {
      console.warn('Twikoo container (#twikoo) not found');
      return;
    }

    const envId = container.getAttribute('data-env-id');
    const path = container.getAttribute('data-path');
    
    if (!envId) {
      console.error('Twikoo envId not provided');
      container.innerHTML = '<div class="text-center py-8 text-red-500">评论系统配置错误</div>';
      return;
    }

    try {
      // 清理容器
      container.innerHTML = '';
      
      // 初始化 Twikoo
      window.twikoo.init({
        envId: envId,
        el: '#twikoo',
        path: path === 'auto' ? location.pathname : path,
        lang: 'zh-CN',
        onCommentLoaded: renderCommentMarkdown
      });
      
      setupOwOFix();
      console.log('Twikoo initialized successfully');

      // 监听动态添加的评论，重新渲染 markdown
      const mo = new MutationObserver(() => renderCommentMarkdown());
      mo.observe(document.getElementById('twikoo'), { childList: true, subtree: true });
    } catch (error) {
      console.error('Failed to initialize Twikoo:', error);
      container.innerHTML = `
        <div class="text-center py-8 text-red-500">
          <p>评论系统初始化失败</p>
          <p class="text-sm mt-1">${error.message}</p>
          <button onclick="location.reload()" class="btn btn-primary btn-sm mt-2">
            重新加载
          </button>
        </div>
      `;
    }
  }

  function handlePageInit() {
    // 重置重试计数
    window.twikooRetryCount = 0;
    
    // 等待 Twikoo 脚本加载完成后初始化
    waitForTwikoo(initializeTwikoo);
  }

  // 首次加载处理
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', handlePageInit);
  } else {
    // DOM 已经准备就绪，延迟一点执行以确保所有脚本都加载完成
    setTimeout(handlePageInit, 100);
  }

  // Astro ViewTransitions 支持
  document.addEventListener('astro:after-swap', () => {
    console.log('Page swapped, reinitializing Twikoo');
    setTimeout(handlePageInit, 150);
  });

  // 页面可见性变化处理（可选）
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      const container = document.getElementById('twikoo');
      if (container && container.children.length === 0) {
        console.log('Page became visible, checking Twikoo');
        setTimeout(handlePageInit, 100);
      }
    }
  });
</script>

<style is:global>
  #twikoo {
    font-family: 'Geist', system-ui, sans-serif;
    min-height: 200px;
  }

  /* ── 输入框 (昵称/邮箱/网址 + 评论正文) ── */
  #twikoo .el-textarea__inner {
    background-color: oklch(var(--b2)) !important;
    border-color: oklch(var(--bc) / 0.2) !important;
    color: oklch(var(--bc)) !important;
    border-radius: 0.75rem !important;
    min-height: 8rem !important;
  }

  #twikoo .el-textarea__inner:focus {
    border-color: oklch(var(--p)) !important;
    outline: none !important;
    box-shadow: 0 0 0 1px oklch(var(--p) / 0.3) !important;
  }

  /* 带 prepend 标签的输入组合 (昵称/邮箱/网址) */
  #twikoo .el-input-group {
    border: 1px solid oklch(var(--bc) / 0.2) !important;
    border-radius: 0.75rem !important;
    overflow: hidden !important;
  }

  #twikoo .el-input-group .el-input__inner {
    background-color: oklch(var(--b2)) !important;
    border: none !important;
    color: oklch(var(--bc)) !important;
  }

  #twikoo .el-input-group .el-input__inner:focus {
    outline: none !important;
    box-shadow: none !important;
  }

  #twikoo .el-input-group:focus-within {
    border-color: oklch(var(--p)) !important;
    box-shadow: 0 0 0 1px oklch(var(--p) / 0.3) !important;
  }

  #twikoo .el-input-group__prepend {
    background-color: oklch(var(--b3)) !important;
    border: none !important;
    border-right: 1px solid oklch(var(--bc) / 0.2) !important;
    color: oklch(var(--bc) / 0.8) !important;
  }

  /* ── 评论内容中的 blockquote ── */
  #twikoo .tk-content blockquote {
    border-left: 3px solid oklch(var(--p) / 0.6) !important;
    padding: 0.4rem 0.8rem !important;
    margin: 0.4rem 0 !important;
    background: oklch(var(--b2) / 0.5) !important;
    border-radius: 0 0.5rem 0.5rem 0 !important;
    color: oklch(var(--bc) / 0.85) !important;
    font-style: italic !important;
    font-size: 0.9em !important;
  }

  #twikoo .tk-content blockquote p {
    margin: 0.2rem 0 !important;
  }

  /* ── 评论内容中的代码、表格、列表等 markdown 元素 ── */
  #twikoo .tk-content h1,
  #twikoo .tk-content h2,
  #twikoo .tk-content h3,
  #twikoo .tk-content h4,
  #twikoo .tk-content h5,
  #twikoo .tk-content h6 {
    margin: 0.5rem 0 0.25rem !important;
    font-weight: 600 !important;
    line-height: 1.3 !important;
    color: oklch(var(--bc)) !important;
  }
  #twikoo .tk-content h1 { font-size: 1.15rem !important; }
  #twikoo .tk-content h2 { font-size: 1.05rem !important; }
  #twikoo .tk-content h3 { font-size: 1rem !important; }
  #twikoo .tk-content h4,
  #twikoo .tk-content h5,
  #twikoo .tk-content h6 { font-size: 0.9rem !important; }

  #twikoo .tk-content code {
    background: oklch(var(--b3)) !important;
    padding: 0.15rem 0.4rem !important;
    border-radius: 0.3rem !important;
    font-size: 0.85em !important;
    color: oklch(var(--bc)) !important;
  }

  #twikoo .tk-content pre {
    background: oklch(var(--b2)) !important;
    border: 1px solid oklch(var(--bc) / 0.1) !important;
    border-radius: 0.5rem !important;
    padding: 0.75rem !important;
    overflow-x: auto !important;
  }

  #twikoo .tk-content pre code {
    background: none !important;
    padding: 0 !important;
    border-radius: 0 !important;
  }

  #twikoo .tk-content table {
    border-collapse: collapse !important;
    width: 100% !important;
    margin: 0.5rem 0 !important;
    font-size: 0.85em !important;
  }

  #twikoo .tk-content th,
  #twikoo .tk-content td {
    border: 1px solid oklch(var(--bc) / 0.2) !important;
    padding: 0.4rem 0.6rem !important;
    text-align: left !important;
  }

  #twikoo .tk-content th {
    background: oklch(var(--b3)) !important;
    font-weight: 600 !important;
  }

  #twikoo .tk-content ul,
  #twikoo .tk-content ol {
    padding-left: 1.5rem !important;
    margin: 0.3rem 0 !important;
  }

  #twikoo .tk-content hr {
    border: none !important;
    border-top: 1px solid oklch(var(--bc) / 0.15) !important;
    margin: 0.5rem 0 !important;
  }

  /* ── 提交按钮 ── */
  #twikoo .el-button--primary {
    background-color: oklch(var(--p)) !important;
    border-color: oklch(var(--p)) !important;
    color: oklch(var(--pc)) !important;
    border-radius: 0.75rem !important;
  }

  #twikoo .el-button--primary:hover {
    background-color: oklch(var(--p) / 0.85) !important;
    border-color: oklch(var(--p) / 0.85) !important;
  }

  #twikoo .el-button:not(.el-button--primary) {
    border-radius: 0.75rem !important;
  }

  /* ── 评论列表 ── */
  #twikoo .tk-comment,
  #twikoo .tk-replies-wrap {
    border-color: oklch(var(--bc) / 0.15) !important;
  }

  #twikoo .tk-comment .tk-main {
    color: oklch(var(--bc)) !important;
  }

  #twikoo .tk-comment .tk-meta span {
    color: oklch(var(--bc) / 0.6) !important;
  }

  #twikoo .tk-comment .tk-nick-link {
    color: oklch(var(--bc)) !important;
  }

  #twikoo .tk-comment .tk-nick-link:hover {
    color: oklch(var(--p)) !important;
  }

  /* ── 点赞/点踩/回复按钮 ── */
  #twikoo .tk-action-link,
  #twikoo .tk-action-icon,
  #twikoo .tk-actions button {
    color: oklch(var(--p)) !important;
  }

  #twikoo .tk-action-link:hover,
  #twikoo .tk-action-link.tk-liked,
  #twikoo .tk-action-link.tk-disliked,
  #twikoo .tk-actions button:hover {
    color: oklch(var(--p) / 0.75) !important;
  }

  /* ── 链接 ── */
  #twikoo .tk-comment a {
    color: oklch(var(--p)) !important;
  }

  #twikoo .tk-comment a:hover {
    color: oklch(var(--p) / 0.75) !important;
  }

  /* ── 表情包容器 ── */
  #twikoo .tk-owo-container {
    background-color: oklch(var(--b2)) !important;
    border-color: oklch(var(--bc) / 0.2) !important;
    border-radius: 0.75rem !important;
  }

  /* ── 表情包弹出面板 ── */
  #twikoo .OwO .OwO-body {
    background-color: oklch(var(--b1)) !important;
    border-color: oklch(var(--bc) / 0.2) !important;
    border-radius: 0.75rem !important;
    color: oklch(var(--bc)) !important;
  }

  #twikoo .OwO .OwO-body .OwO-bar {
    border-top-color: oklch(var(--bc) / 0.15) !important;
  }

  #twikoo .OwO .OwO-body .OwO-items .OwO-item:hover {
    background-color: oklch(var(--p) / 0.1) !important;
  }

  #twikoo .OwO .OwO-body .OwO-bar .OwO-packages li:hover,
  #twikoo .OwO .OwO-body .OwO-bar .OwO-packages .OwO-package-active {
    background-color: oklch(var(--p) / 0.1) !important;
  }

  /* ── 表情面板底部显示不全修复 ── */
  #twikoo .OwO {
    overflow: visible !important;
  }
  #twikoo .OwO .OwO-body {
    max-height: 50vh !important;
    overflow-y: auto !important;
  }
  #twikoo .OwO .OwO-body .OwO-items {
    max-height: none !important;
    overflow: visible !important;
  }

  /* ── 评论数 / 图标 ── */
  #twikoo .tk-icon.__comments,
  #twikoo .tk-comments-count {
    color: oklch(var(--p)) !important;
  }

  /* ── 排序按钮 (最早/最新/热门) ── */
  #twikoo .tk-sort-item {
    color: oklch(var(--p) / 0.6) !important;
  }

  #twikoo .tk-sort-item.__active,
  #twikoo .tk-sort-item:focus {
    color: oklch(var(--p)) !important;
  }

  #twikoo .tk-sort-item:hover {
    color: oklch(var(--p) / 0.8) !important;
  }

  /* ── 标签与额外信息 ── */
  #twikoo .tk-tag,
  #twikoo .tk-extras {
    color: oklch(var(--bc) / 0.6) !important;
  }

  /* ── 头像 ── */
  #twikoo .tk-avatar {
    border-radius: 0.75rem !important;
  }

  /* ── 评论间距 ── */
  #twikoo .tk-comment {
    margin-bottom: 1rem !important;
  }

  /* ── 加载状态 ── */
  #twikoo .tk-loading {
    color: oklch(var(--bc) / 0.6) !important;
  }

  #twikoo .el-loading-spinner .path {
    stroke: oklch(var(--p)) !important;
  }

  #twikoo .el-loading-spinner i,
  #twikoo .el-loading-spinner .el-loading-text {
    color: oklch(var(--p)) !important;
  }

  /* ── loading 动画 ── */
  .animate-spin {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>