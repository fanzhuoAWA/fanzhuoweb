---
interface Props {
  path: string;
}

const { path } = Astro.props;
---

<div id="waline-comment" class="mt-12" data-path={path}>
  <p id="waline-status">正在加载评论系统...</p>
</div>

<script>
  if (typeof window !== 'undefined') {
    console.log('WalineComment component mounted');
    console.log('Path:', '<%= path %>');
    
    // 检查元素是否存在
    const commentElement = document.getElementById('waline-comment');
    if (!commentElement) {
      console.error('Waline comment element not found!');
      return;
    }
    
    // 使用 HTTPS 加载 Waline 客户端
    import('https://unpkg.com/@waline/client@v2/dist/waline.js')
      .then(({ init }) => {
        console.log('Waline client loaded successfully');
        
        init({
          serverURL: 'https://coo.fanzhuo.xyz/',
          el: '#waline-comment',
          path: '<%= path %>',
          dark: 'html[data-theme="dark"]',
          emoji: [
            'https://unpkg.com/@waline/emojis@1.1.0/weibo',
            'https://unpkg.com/@waline/emojis@1.1.0/alus',
            'https://unpkg.com/@waline/emojis@1.1.0/bilibili',
          ],
          locale: {
            placeholder: '欢迎留言交流~ (支持 Markdown 语法)'
          },
          reaction: true,
          search: false,
        });
        
        console.log('Waline initialized successfully');
        document.getElementById('waline-status').style.display = 'none';
      })
      .catch(error => {
        console.error('Failed to load Waline:', error);
        document.getElementById('waline-status').textContent = 
          '评论系统加载失败: ' + error.message;
      });
  }
</script>

<style>
  #waline-comment {
    --waline-theme-color: #3b82f6;
    --waline-active-color: #1d4ed8;
  }
  
  [data-theme="dark"] #waline-comment {
    --waline-bgcolor: #1f2937;
    --waline-text-color: #e5e7eb;
    --waline-border-color: #374151;
  }
  
  #waline-status {
    text-align: center;
    color: #6b7280;
    font-style: italic;
  }
</style>
